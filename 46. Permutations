class Solution(object):
    def permute(self, nums):
        l = []

        if len(nums) == 1:
            return [nums[:]]
        
        for i in range(len(nums)):
            n = nums.pop(0)
            perms = self.permute(nums)

            for j in perms:
                j.append(n)
            l.extend(perms)
            nums.append(n)

        return l
